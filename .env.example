# ─────────────────────────────────────────────────────────────────────────────
# docx-agent environment configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# setup.sh auto-detects this from your local Postgres socket and fills it in.
# You normally do not need to edit this line.
# If auto-detection failed, set it manually:
#   Standard port:  postgresql://YOUR_USER@localhost/docx_agent
#   Custom port:    postgresql://YOUR_USER@localhost:PORT/docx_agent
DOCX_AGENT_DATABASE_DSN=postgresql://localhost/docx_agent

# ── OpenAI / LLM endpoint ─────────────────────────────────────────────────────
#
# Option A — Direct OpenAI API key (home / dev use):
OPENAI_API_KEY=sk-...

# Option B — RBC internal gateway (work computer):
#   Comment out OPENAI_API_KEY above, uncomment and fill in below.
#
# OPENAI_BASE_URL=https://your-rbc-gateway.example.com/openai/v1
# OPENAI_OAUTH_TOKEN_URL=https://your-rbc-idp.example.com/oauth2/token
# OPENAI_OAUTH_CLIENT_ID=your-client-id
# OPENAI_OAUTH_CLIENT_SECRET=your-client-secret
# OPENAI_OAUTH_SCOPE=openai

# ── Model and token configuration ────────────────────────────────────────────
# OPENAI_CHAT_MODEL sets the model name for extraction, retrieval, vision, and
# judge calls. Required when using an internal gateway with a custom deployment.
# Leave unset to use the code defaults (gpt-5-mini).
#
# OPENAI_CHAT_MODEL=your-internal-model-deployment-name
# OPENAI_EMBEDDING_MODEL=your-internal-embedding-deployment-name
#
# Internal gateways often have lower per-request token limits than direct OpenAI.
# Set this to the maximum your gateway allows (e.g. 16384, 32768).
# OPENAI_MAX_COMPLETION_TOKENS=32768

# ── SSL ───────────────────────────────────────────────────────────────────────
# Set to 1 to skip SSL verification (not recommended for production).
# rbc_security is installed automatically by setup.sh if available on PyPI.
# OPENAI_SKIP_SSL_VERIFY=0
